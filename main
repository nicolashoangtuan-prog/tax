let qIdx=0, totalScore=0, gScore=0, correct=0, wrong=0, selOpt=null, answered=false, gAnswered=0;

function renderQ() {
  const q = questions[qIdx];
  const dc = {easy:'background:rgba(74,140,106,.15);color:#80c49e;border:1px solid rgba(74,140,106,.3)',medium:'background:rgba(201,168,76,.12);color:var(--gold2);border:1px solid var(--gold-dim)',hard:'background:rgba(196,75,75,.15);color:#e08080;border:1px solid rgba(196,75,75,.3)'};
  const dm = {easy:'🟢 Easy +5pts',medium:'🟡 Medium +10pts',hard:'🔴 Hard +15pts'};
  document.getElementById('qarea').innerHTML = `
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
      <span style="font-family:var(--mono);font-size:.58rem;padding:3px 8px;border-radius:3px;${dc[q.d]}">${dm[q.d]}</span>
      <span class="q-source-tag">${q.src}</span>
    </div>
    <div class="q-text">${q.q}</div>
    <div class="opts" id="optsDiv">
      ${q.opts.map((o,i)=>`<button class="opt" onclick="selOpt_(${i})" id="opt${i}"><span class="opt-ltr">${'ABCD'[i]}</span>${o}</button>`).join('')}
    </div>
    <div class="explain" id="expDiv"><strong>Explanation:</strong> ${q.exp}</div>
  `;
  selOpt=null; answered=false;
  document.getElementById('submitBtn').style.display='none';
  document.getElementById('nextBtn').style.display='none';
  const pm = document.getElementById('ptsmsg'); pm.style.display='none';
  document.getElementById('qpf').style.width=((qIdx+1)/questions.length*100)+'%';
  document.getElementById('qn').textContent=qIdx+1;
}

function selOpt_(i) {
  if(answered) return;
  selOpt=i;
  document.querySelectorAll('.opt').forEach((b,idx)=>{
    b.style.borderColor = idx===i ? 'var(--gold)' : 'var(--border)';
    b.style.background = idx===i ? 'var(--gold-pale)' : 'var(--surface)';
    b.querySelector('.opt-ltr').style.borderColor = idx===i ? 'var(--gold)' : 'var(--border)';
  });
  document.getElementById('submitBtn').style.display='inline-block';
}

function submitQ() {
  if(selOpt===null||answered) return;
  answered=true;
  const q=questions[qIdx];
  const ok=selOpt===q.ans;
  const pts=ok?q.pts:-q.neg;
  totalScore+=pts; gScore+=pts;
  if(ok) correct++; else wrong++;
  gAnswered++;
  document.querySelectorAll('.opt').forEach((b,i)=>{
    b.disabled=true;
    if(i===q.ans) b.classList.add('correct');
    else if(i===selOpt&&!ok) b.classList.add('wrong');
  });
  document.getElementById('expDiv').style.display='block';
  const pm=document.getElementById('ptsmsg');
  pm.style.display='block'; pm.className='pts-msg '+(ok?'pts-pos':'pts-neg');
  pm.textContent=ok?`+${pts} pts`:`${pts} pts`;
  document.getElementById('qs').textContent=totalScore;
  document.getElementById('qc').textContent=correct;
  document.getElementById('qw').textContent=wrong;
  document.getElementById('gscore').textContent=Math.max(0,gScore);
  document.getElementById('gans').textContent=gAnswered;
  document.getElementById('submitBtn').style.display='none';
  if(qIdx<questions.length-1) {
    document.getElementById('nextBtn').style.display='inline-block';
  } else {
    const fb=document.createElement('button');
    fb.className='btn';fb.textContent='See Results →';fb.onclick=showResults;
    document.querySelector('.q-nav').appendChild(fb);
  }
}

function nextQ(){qIdx++;renderQ();}

function showResults(){
  const pct=(correct/questions.length*100).toFixed(0);
  const msgs=[[0,'Keep studying — revisit the lesson sections and retry.'],[40,'Good foundation. Focus on the conflict/priority and international tax sections.'],[60,'Solid! Review the harder transfer pricing and GAAR questions.'],[80,'Strong performance — excellent integration of lesson and case study.'],[95,'⚖ Outstanding. Near-mastery of Singapore tax law.']];
  let msg=msgs[0][1];
  for(const [t,m] of msgs){if(parseInt(pct)>=t) msg=m;}
  document.getElementById('finalScore').textContent=totalScore+' pts';
  document.getElementById('finalMsg').textContent=msg;
  document.getElementById('finalBreak').textContent=`${correct} correct / ${wrong} wrong / ${questions.length} questions | ${pct}% accuracy`;
  document.getElementById('scoreModal').classList.add('show');
}

function restartQ(){
  qIdx=0;totalScore=0;correct=0;wrong=0;selOpt=null;answered=false;
  document.getElementById('scoreModal').classList.remove('show');
  document.getElementById('qs').textContent=0;
  document.getElementById('qc').textContent=0;
  document.getElementById('qw').textContent=0;
  renderQ();
}

// ══ SIDEBAR ACTIVE ══
const allSecs = document.querySelectorAll('[id]');
const sLinks = document.querySelectorAll('#sidebar a');
window.addEventListener('scroll',()=>{
  let cur='';
  allSecs.forEach(s=>{if(s.id&&window.scrollY>=s.offsetTop-80)cur=s.id;});
  sLinks.forEach(l=>{l.classList.remove('active');if(l.getAttribute('href')==='#'+cur)l.classList.add('active');});
});

renderQ();
</script>
</body>
</html>
