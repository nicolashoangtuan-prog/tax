// ══ MODE SYSTEM ══
function setMode(m) {
  document.body.className = 'mode-' + m;
  document.querySelectorAll('.mode-tab').forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
  if (m === 'quiz') {
    setTimeout(() => document.getElementById('quiz-sec').scrollIntoView({behavior:'smooth'}), 100);
  }
}

// ══ TAB SYSTEM ══
function switchTab(btn, containerId, panelId) {
  const con = document.getElementById(containerId);
  con.querySelectorAll('.tab-pnl').forEach(p => p.classList.remove('active'));
  btn.closest('.sec,.card').querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById(panelId).classList.add('active');
}

// ══ CALCULATORS ══
const fmt = n => 'S$' + n.toLocaleString('en-SG', {minimumFractionDigits:2, maximumFractionDigits:2});

document.getElementById('c_type').addEventListener('change', function() {
  document.getElementById('c_rate_row').style.display = this.value === 'pioneer' ? 'flex' : 'none';
});

function calcCIT() {
  const ci = parseFloat(document.getElementById('c_ci').value) || 0;
  const type = document.getElementById('c_type').value;
  let tax = 0, notes = '';
  if (type === 'normal') {
    const ex1 = Math.min(ci,10000)*0.75, ex2 = Math.min(Math.max(ci-10000,0),190000)*0.50;
    tax = (ci - ex1 - ex2) * 0.17;
    notes = `Ex1 (75% of 1st S$10K): ${fmt(ex1)}\nEx2 (50% of next S$190K): ${fmt(ex2)}\nTotal exemption: ${fmt(ex1+ex2)}`;
  } else if (type === 'startup') {
    const ex1 = Math.min(ci,100000)*0.75, ex2 = Math.min(Math.max(ci-100000,0),100000)*0.50;
    tax = (ci - ex1 - ex2) * 0.17;
    notes = `Startup: 75% of 1st S$100K = ${fmt(ex1)}\n50% of next S$100K = ${fmt(ex2)}`;
  } else {
    const r = (parseFloat(document.getElementById('c_rate').value)||10)/100;
    tax = ci * r; notes = `Incentive rate: ${(r*100).toFixed(1)}% applied`;
  }
  const el = document.getElementById('c_out');
  el.style.display = 'block';
  el.textContent = `Chargeable Income: ${fmt(ci)}\n${notes}\nTax Payable: ${fmt(tax)}\nEffective Rate: ${ci>0?(tax/ci*100).toFixed(2):'0.00'}%`;
}

function calcGST() {
  const it = parseFloat(document.getElementById('g_it').value)||0;
  const tx = parseFloat(document.getElementById('g_tx').value)||0;
  const tot = parseFloat(document.getElementById('g_tot').value)||1;
  const raw = tx/tot;
  const rounded = Math.ceil(raw*100)/100;
  const recov = it * rounded;
  const blocked = it - recov;
  const dm = Math.min(0.05*it, 12000);
  const el = document.getElementById('g_out');
  el.style.display='block';
  el.textContent = `Raw Ratio: ${(raw*100).toFixed(4)}%\nCEILING to whole %: ${(rounded*100).toFixed(0)}%\nRecoverable Input Tax: ${fmt(recov)}\nBlocked Input Tax: ${fmt(blocked)}\nDe minimis threshold: ${fmt(dm)}\nDe minimis applies? ${blocked<=dm?'✅ YES — full recovery':'❌ No — partial applies'}`;
}

function calcSD() {
  const p = parseFloat(document.getElementById('s_price').value)||0;
  const mv = parseFloat(document.getElementById('s_mv').value)||0;
  const b = Math.max(p,mv);
  const absdRates = {sc1:0,sc2:0.20,sc3:0.30,spr1:0.05,spr2:0.30,fg:0.60,entity:0.65};
  const buyer = document.getElementById('s_buyer').value;
  const bands = [[180000,.01],[180000,.02],[640000,.03],[500000,.04],[1500000,.05],[Infinity,.06]];
  let rem=b, bsd=0;
  for(const [sz,r] of bands){const t=Math.min(rem,sz);bsd+=t*r;rem-=t;if(rem<=0)break;}
  const absd = b * (absdRates[buyer]||0);
  const el = document.getElementById('s_out');
  el.style.display='block';
  el.textContent = `BSD Basis (MAX of price/MV): ${fmt(b)}\nBSD: ${fmt(bsd)}\nABSD Rate: ${((absdRates[buyer]||0)*100).toFixed(0)}%\nABSD: ${fmt(absd)}\nTOTAL STAMP DUTY: ${fmt(bsd+absd)}\nEffective Rate: ${((bsd+absd)/p*100).toFixed(1)}% of purchase price`;
}

function calcQDMTT() {
  const inc = parseFloat(document.getElementById('p_income').value)||0;
  const tax = parseFloat(document.getElementById('p_tax').value)||0;
  const etr = inc>0 ? tax/inc : 0;
  const topUp = Math.max(0.15-etr,0);
  const qdmtt = inc * topUp;
  const el = document.getElementById('p_out');
  el.style.display='block';
  el.textContent = `ETR: ${(etr*100).toFixed(2)}%\nTop-Up % = MAX(15% - ${(etr*100).toFixed(2)}%, 0) = ${(topUp*100).toFixed(2)}%\nQDMTT: ${fmt(qdmtt)}\nTotal Tax (CIT + QDMTT): ${fmt(tax+qdmtt)}\nCombined ETR: ${inc>0?((tax+qdmtt)/inc*100).toFixed(2):0}%`;
}

